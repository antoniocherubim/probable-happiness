{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "summary", "findings", "tests_required"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["APPROVED", "CHANGES_REQUESTED", "BLOCKED"]
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "title", "details", "files"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "title": {
            "type": "string"
          },
          "details": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "tests_required": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
