# Example credential file for the local agent Telegram bridge.
# Copy outside the Git tree, e.g.:
#   mkdir -p ~/.config/codex-cursor-agent-loop
#   cp scripts/agents/telegram-bridge.env.example \
#     ~/.config/codex-cursor-agent-loop/telegram.env
#   chmod 600 ~/.config/codex-cursor-agent-loop/telegram.env
#
# Then either export AGENT_TELEGRAM_CREDENTIALS_FILE pointing at that path,
# or load the file via systemd EnvironmentFile=.
#
# NEVER commit real tokens. Run the bridge with systemd --user, never as root.

AGENT_TELEGRAM_BOT_TOKEN=replace-with-bot-token-from-botfather
AGENT_TELEGRAM_ALLOWED_USER_ID=123456789
AGENT_TELEGRAM_ALLOWED_CHAT_ID=123456789

# Optional overrides:
# AGENT_TELEGRAM_API_BASE=https://api.telegram.org
# AGENT_TELEGRAM_POLL_TIMEOUT_SEC=25
# AGENT_HUMAN_APPROVAL_TIMEOUT_SEC=3600
# AGENT_RUNS_ROOT=/absolute/path/to/external/state/root
